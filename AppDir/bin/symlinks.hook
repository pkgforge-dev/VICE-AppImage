#!/bin/sh

_make_symlinks_in_path() {
	[ -n "$APPIMAGE" ] || return 1
	[ -n "$APPDIR" ] || return 1
	mkdir -p "$BINDIR"
	cd "$APPDIR"/bin
	set +e
	set -- ./c1541 ./cartconv ./petcat ./vsid ./x*
	for b do
		ln -sv "$APPIMAGE" "$BINDIR"/"${b##*/}" 2>/dev/null
	done
	exit 0
}

if [ "$1" = '--make-symlinks' ]; then
	_make_symlinks_in_path
fi
